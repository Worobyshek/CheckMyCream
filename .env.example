# Public frontend base URL for backend API requests.
# Leave empty for local web development with Next.js API routes.
# Set this in Android/mobile builds to your deployed backend origin, for example:
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com
NEXT_PUBLIC_API_BASE_URL=https://check-my-cream.vercel.app/

# Comma-separated list of allowed browser/mobile origins for cross-origin API requests.
# Example:
# CORS_ALLOWED_ORIGINS=https://your-web-app.vercel.app,capacitor://localhost,http://localhost
CORS_ALLOWED_ORIGINS=

# AI provider selection: remote | mock
AI_PROVIDER=remote

# OpenRouter chat completions endpoint. Used only on the server.
AI_API_URL=https://openrouter.ai/api/v1/chat/completions

# OpenRouter secret API key. Never expose on the client.
AI_API_KEY=__PASTE_KEY_HERE__

# OpenRouter model identifier. Used only on the server.
AI_MODEL=qwen/qwen3.6-plus:free

# OCR provider selection: remote
OCR_PROVIDER=remote

# OCR.Space endpoint. Used only on the server.
OCR_API_URL=https://api.ocr.space/parse/image

# OCR.Space secret API key. Never expose on the client.
OCR_API_KEY=__PASTE_KEY_HERE__
